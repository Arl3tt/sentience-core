++++ b/core/tools/sandbox_worker.py
+@@ -0,0 +1,63 @@
+ +#!/usr/bin/env python3
+ +"""Sandbox worker that pulls jobs from Redis and executes them in the sandbox.
+ +
+ +This script is intended to run inside a dedicated worker container. It blocks on
+ +the Redis queue and executes incoming jobs using the local docker-compose
+ +sandbox runtime (the same sandbox image), or runs them directly if configured.
+ +"""
+ +
+ +import os
+ +import json
+ +import subprocess
+ +import time
+ +from core.queue import dequeue_blocking
+ +
+ +def _run_job(job: dict) -> dict:
+ +    cmd = job.get("command")
+ +    timeout = job.get("timeout", 30)
+ +    compose_file = os.path.join(os.path.dirname(os.path.dirname(__file__)), "docker", "docker-compose.yml")
+ +
+ +    try:
+ +        subprocess.run(["docker-compose", "-f", compose_file, "build"], check=True)
+ +    except Exception:
+ +        # build may be unnecessary in worker - ignore errors
+ +        pass
+ +
+ +    try:
+ +        res = subprocess.run([
+ +            "docker-compose", "-f", compose_file,
+ +            "run", "--rm", "sandbox", "/bin/bash", "-c", cmd
+ +        ], capture_output=True, text=True, timeout=timeout)
+ +        return {"status": "success" if res.returncode == 0 else "error", "output": res.stdout, "error": res.stderr, "code": res.returncode}
+ +    except subprocess.TimeoutExpired:
+ +        return {"status": "timeout", "output": "", "error": f"Timed out after {timeout}s", "code": -1}
+ +    except Exception as e:
+ +        return {"status": "error", "output": "", "error": str(e), "code": -1}
+ +
+ +def main():
+ +    print("[worker] Starting sandbox worker, waiting for jobs...")
+ +    while True:
+ +        try:
+ +            job = dequeue_blocking(0)
+ +            if job is None:
+ +                continue
+ +            print(f"[worker] Got job {job.get('id')} -> {job.get('command')}")
+ +            result = _run_job(job)
+ +            print(f"[worker] Job {job.get('id')} finished: {result.get('status')}")
+ +        except KeyboardInterrupt:
+ +            print("[worker] Exiting on user request")
+ +            break
+ +        except Exception as e:
+ +            print(f"[worker] Error while processing job: {e}")
+ +            time.sleep(1)
+ +
+ +if __name__ == '__main__':
+ +    main()
+
+
