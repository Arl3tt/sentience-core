++++ b/core/queue.py
+@@ -0,0 +1,72 @@
+ +"""Redis-backed job queue helpers.
+ +
+ +Provides simple enqueue/dequeue helpers using Redis LISTs. The worker script
+ +will block on BLPOP to receive tasks. Messages are JSON-encoded dicts with at
+ +least: id, command, timeout, meta.
+ +"""
+ +import os
+ +import json
+ +import uuid
+ +from typing import Optional, Dict, Any
+ +
+ +REDIS_URL = os.getenv("REDIS_URL", None)
+ +
+ +def _get_redis_client():
+ +    if not REDIS_URL:
+ +        return None
+ +    try:
+ +        import redis
+ +    except Exception:
+ +        return None
+ +    return redis.from_url(REDIS_URL, decode_responses=True)
+ +
+ +QUEUE_KEY = os.getenv("SANDBOX_QUEUE_KEY", "sandbox:jobs")
+ +
+ +def enqueue_sandbox_job(command: str, timeout: int = 30, meta: Optional[Dict[str, Any]] = None) -> Dict[str, Any]:
+ +    """Enqueue a sandbox job and return job descriptor.
+ +
+ +    If Redis is not configured or the client can't be created, raises RuntimeError.
+ +    """
+ +    r = _get_redis_client()
+ +    if r is None:
+ +        raise RuntimeError("Redis client not available (set REDIS_URL and install redis package)")
+ +
+ +    job = {
+ +        "id": str(uuid.uuid4()),
+ +        "command": command,
+ +        "timeout": int(timeout),
+ +        "meta": meta or {}
+ +    }
+ +    r.rpush(QUEUE_KEY, json.dumps(job))
+ +    return job
+ +
+ +def dequeue_blocking(blpop_timeout: int = 0) -> Optional[Dict[str, Any]]:
+ +    """Blocking pop a job from the queue. Returns job dict or None if timeout.
+ +
+ +    blpop_timeout=0 => block indefinitely
+ +    """
+ +    r = _get_redis_client()
+ +    if r is None:
+ +        raise RuntimeError("Redis client not available")
+ +    item = r.blpop(QUEUE_KEY, timeout=blpop_timeout)
+ +    if not item:
+ +        return None
+ +    # item is (key, value)
+ +    payload = item[1]
+ +    return json.loads(payload)
+
+
